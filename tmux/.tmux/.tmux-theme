# Optimized for ANSI colors

# Onedark
# set to the terminal black color
# BACKGROUND_COLOR='#2c323d'
# set to the terminal background color
# ACTIVE_COLOR='#282c34'

#Gruvbox
# BACKGROUND_COLOR='#373737'
# ACTIVE_COLOR='#272727'

# Monokai Tasty
# BACKGROUND_COLOR='#2d2d2d'
# ACTIVE_COLOR='#252525'

# Noctis Minimus
# BACKGROUND_COLOR='#21313c'
# ACTIVE_COLOR='#1c2932'
#
# Solarized Light
# ACTIVE_COLOR='#fdf6e3'
# BACKGROUND_COLOR='#eee8d5'

# Solarized Dark
# ACTIVE_COLOR='#002b36'
# BACKGROUND_COLOR='#073642'

# Spacevim
ACTIVE_COLOR='#282a2e'
BACKGROUND_COLOR='#313337'

# Ayu Mirage
# BACKGROUND_COLOR='#272f3d'
# ACTIVE_COLOR='#212632'

set -g status-position bottom
set -g status-justify "left"
#set -g status-style "bg=0"
set -g status-style "bg=8"
# Set this to the color of the background
set -g window-style "bg=$BACKGROUND_COLOR"

set -g status-left " #[fg=colour05][#S] "
set -g status-left-length 100

set -g status-right " #[fg=colour03]%I:%M %p  %b %d #{?battery_percentage, ,}#{battery_status_fg}#{battery_percentage} "
set -g status-right-style "bold"
set -g status-right-length 100

# set -g window-status-current-style "bold fg=4 bg=0"
set -g window-status-current-style "bold fg=4 bg=8"
# set -g window-status-style "fg=8 bg=0"
set -g window-status-style "fg=8 bg=8"
set -g window-status-format " #{?#{==:#{window_name},zsh},#{b:pane_current_path},#W}#{?window_zoomed_flag,.Z,} "
set -g window-status-current-format " #{?#{==:#{window_name},zsh},#{b:pane_current_path},#W}#{?window_zoomed_flag,.Z,} "
set -g window-status-separator ""

set -g pane-active-border-style "fg=$BACKGROUND_COLOR bg=$BACKGROUND_COLOR"
set -g pane-border-style "fg=$BACKGROUND_COLOR bg=$BACKGROUND_COLOR"

set -g window-active-style "bg=$ACTIVE_COLOR"
