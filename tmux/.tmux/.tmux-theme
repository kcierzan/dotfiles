# Optimized for ANSI colors

# You're going to want a patched font.
# Available here: https://github.com/ryanoasis/nerd-fonts

set-option -g status-position bottom

set -g status-bg "default"
set -g message-command-fg "colour04"
set -g status-justify "left"
set -g status-left-length "100"
set -g status "on"
set -g pane-active-border-fg "colour04"
set -g message-bg "colour11"
set -g status-right-length "100"
set -g status-right-attr "none"
set -g message-fg "colour00"
set -g message-command-bg "default"
set -g status-attr "none"
set -g pane-border-fg "default"
set -g status-left-attr "none"
setw -g window-status-fg "colour188"
setw -g window-status-attr "none"
setw -g window-status-activity-bg "default"
setw -g window-status-activity-attr "none"
setw -g window-status-activity-fg "colour04"
setw -g window-status-separator ""
setw -g window-status-bg "default"
set -g @batt_charged_icon "⊙"
set -g @batt_charging_icon "⊕"
set -g @batt_discharging_icon "⊖"
set -g @batt_attached_icon "⊗"
set -g status-left ""
set -g status-right "#[fg=colour04] %b %d#[fg=colour241] :: #[fg=colour04]%I:%M#[fg=colour241] :: #[fg=colour05]#(cat ~/.scripts/weather.txt) #{battery_status_fg}#{battery_percentage} "
setw -g window-status-format "#[fg=colour241,bg=default]#W "
setw -g window-status-current-format "#[fg=colour05,bg=default]#W "
