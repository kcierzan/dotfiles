# Disable focus follows mouse
switcher - backspace :         chunkc core::unload ffm.so;\
                               khd -e 'mode activate default'
switcher + shift - backspace : chunkc core::load ffm.so;\
                               khd -e 'mode activate default'

# Repeat prefix to quit
switcher + lctrl - space : khd -e "mode activate default"
swap + lctrl - space     : khd -e "mode activate default"
pane + lctrl - space     : khd -e "mode activate default"
grid + lctrl - space     : khd -e "mode activate default"

# Escape to quit
switcher - 0x35          : khd -e "mode activate default"
swap - 0x35              : khd -e "mode activate default"
pane - 0x35              : khd -e "mode activate default"
grid - 0x35              : khd -e "mode activate default"

# Ctrl-C to quit
switcher + lctrl - c     : khd -e "mode activate default"
swap + lctrl - c         : khd -e "mode activate default"
pane + lctrl - c         : khd -e "mode activate default"
grid + lctrl - c         : khd -e "mode activate default"

# -------------- Mode Colors ---------------------------

# Default (blue) (transparent)
khd mode default  on_enter chunkc border::color 0x00ebdbb2
# Switcher (yellow)
khd mode switcher on_enter chunkc border::color 0xFFbfa425
# Swap (red)
khd mode swap     on_enter chunkc border::color 0xFF2e9574 
# Pane (purple)
khd mode pane     on_enter chunkc border::color 0xFFbb6dc4
# Grid (green)
khd mode grid     on_enter chunkc border::color 0xFF91b4b7

# --------------- switcher mode -----------------------
lctrl - space        : khd -e "mode activate switcher"
switcher - a         : khd -e "mode activate swap"
switcher - d         : khd -e "mode activate pane"
switcher - y         : khd -e "mode activate grid"

switcher - r         : khd -e "reload"

switcher - return    : open -na /Applications/iTerm.app;\
                           khd -e "mode activate default"

switcher + shift - r : brew services restart chunkwm

# focus windows
switcher - h         : chunkc tiling::window --focus west
switcher - l         : chunkc tiling::window --focus east
switcher - j         : chunkc tiling::window --focus south
switcher - k         : chunkc tiling::window --focus north

# focus monitors
switcher - n         : chunkc tiling::monitor -f next
switcher - m         : chunkc tiling::monitor -f prev

# --------------- swap mode -----------------------
swap - d               :   khd -e "mode activate pane"
swap - s               :   khd -e "mode activate switcher"
swap - y               :   khd -e "mode activate grid"

# Move windows around
swap - h               :   chunkc tiling::window --swap west
swap - j               :   chunkc tiling::window --swap south
swap - k               :   chunkc tiling::window --swap north
swap - l               :   chunkc tiling::window --swap east

# Move windows and adjust layout
swap + shift - h       :   chunkc tiling::window --warp west
swap + shift - j       :   chunkc tiling::window --warp south
swap + shift - k       :   chunkc tiling::window --warp north
swap + shift - l       :   chunkc tiling::window --warp east

# send to monitor
swap - n               :   chunkc tiling::window --send-to-monitor next
swap - m               :   chunkc tiling::window --send-to-monitor prev

# send to monitor with focus
swap + shift - n       :   chunkc tiling::window --send-to-monitor next;\
                           chunkc tiling::monitor -f next
swap + shift - m       :   chunkc tiling::window --send-to-monitor prev;\

# --------------- pane mode -----------------------
pane - a               :   khd -e "mode activate swap"
pane - s               :   khd -e "mode activate switcher"
pane - y               :   khd -e "mode activate grid"

# Gaps and padding
pane - p               :   chunkc tiling::desktop --padding inc
pane - g               :   chunkc tiling::desktop --gap inc
pane + shift - p       :   chunkc tiling::desktop --padding dec
pane + shift - g       :   chunkc tiling::desktop --gap dec

# Toggle gaps and padding
pane - t               :   chunkc tiling::desktop --toggle offset

# Adjust split behavior
pane - e               :   chunkc tiling::desktop --equalize
pane - o               :   chunkc set bsp_split_mode optimal
pane + shift - v       :   chunkc set bsp_split_mode vertical
pane + shift - s       :   chunkc set bsp_split_mode horizontal

pane - f               :   chunkc tiling::window --toggle fullscreen
pane - r               :   chunkc tiling::desktop --rotate 90
pane - m               :   chunkc tiling::window --toggle split

# Resize windows
pane - h               :   chunkc tiling::window --use-temporary-ratio 0.025 --adjust-window-edge west
pane - j               :   chunkc tiling::window --use-temporary-ratio 0.025 --adjust-window-edge south
pane - k               :   chunkc tiling::window --use-temporary-ratio 0.025 --adjust-window-edge north
pane - l               :   chunkc tiling::window --use-temporary-ratio 0.025 --adjust-window-edge east
pane + shift - h       :   chunkc tiling::window --use-temporary-ratio -0.025 --adjust-window-edge west
pane + shift - j       :   chunkc tiling::window --use-temporary-ratio -0.025 --adjust-window-edge south
pane + shift - k       :   chunkc tiling::window --use-temporary-ratio -0.025 --adjust-window-edge north
pane + shift - l       :   chunkc tiling::window --use-temporary-ratio -0.025 --adjust-window-edge east

# --------------- grid mode -----------------------
grid - a         : khd -e "mode activate swap"
grid - s         : khd -e "mode activate switcher"
grid - d         : khd -e "mode activate pane"

grid - y         : chunkc tiling::window --toggle float

# half left
grid - h         : chunkc tiling::window --grid-layout 1:2:0:0:1:1

# half right
grid - l         : chunkc tiling::window --grid-layout 1:2:1:0:1:1

# 70% left
grid + shift - h : chunkc tiling::window --grid-layout 1:10:0:0:7:1

# 30% right?
grid + shift - l : chunkc tiling::window --grid-layout 1:10:7:0:3:1

# ---------------- global keybindings ------------------
lctrl - l         ![iTerm2, Emacs]: khd -p "- right"
lctrl - h         ![iTerm2, Emacs]: khd -p "- left"
