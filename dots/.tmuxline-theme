# Nord
# This tmux statusbar config was created by tmuxline.vim
# on Mon, 17 Apr 2017

set -g status-bg "colour0"
set -g message-command-fg "colour04"
set -g status-justify "left"
set -g status-left-length "100"
set -g status "on"
set -g pane-active-border-fg "colour04"
set -g message-bg "colour11"
set -g status-right-length "100"
set -g status-right-attr "none"
set -g message-fg "colour00"
set -g message-command-bg "colour0"
set -g status-attr "none"
set -g pane-border-fg "colour0"
set -g status-left-attr "none"
setw -g window-status-fg "colour188"
setw -g window-status-attr "none"
setw -g window-status-activity-bg "colour0"
setw -g window-status-activity-attr "none"
setw -g window-status-activity-fg "colour04"
setw -g window-status-separator ""
setw -g window-status-bg "colour0"
set -g @batt_charged_icon " "
set -g @batt_charging_icon ""
set -g @batt_discharging_icon ""
set -g @batt_attached_icon ""
set -g status-left "#[fg=colour0,bg=colour04,bold] #S #[fg=colour04,bg=colour0,nobold,nounderscore,noitalics] "
set -g status-right "#[fg=colour04,bg=colour0,nobold,nounderscore,noitalics] #[fg=colour0,bg=colour04] %B %d  %I:%M #[fg=colour04,bg=colour0,nobold,nounderscore,noitalics] #[fg=colour04,bg=colour0,bold] #(/usr/local/bin/tmux-weather)#[fg=colour04,bg=colour0]  #[fg=colour0,bg=colour04,nobold] #{battery_status_bg} #{battery_icon} #{battery_percentage} "
setw -g window-status-format "#[fg=colour04,bg=colour0] #I #[fg=colour04,bg=colour0] #W "
setw -g window-status-current-format "#[fg=colour04,bg=colour0,nobold,nounderscore,noitalics] #[fg=colour0,bg=colour04] #I #[fg=colour0,bg=colour04] #W #[fg=colour04,bg=colour0,nobold,nounderscore,noitalics]"
