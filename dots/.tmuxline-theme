# This tmux statusbar config was created by tmuxline.vim
# on Mon, 27 Feb 2017

set -g status-bg "colour8"
set -g message-command-fg "colour7"
set -g status-justify "left"
set -g status-left-length "100"
set -g status "on"
set -g pane-active-border-fg "colour6"
set -g message-bg "colour0"
set -g status-right-length "100"
set -g status-right-attr "none"
set -g message-fg "colour7"
set -g message-command-bg "colour0"
set -g status-attr "none"
set -g pane-border-fg "colour0"
set -g status-left-attr "none"
setw -g window-status-fg "colour7"
setw -g window-status-attr "none"
setw -g window-status-activity-bg "colour8"
setw -g window-status-activity-attr "none"
setw -g window-status-activity-fg "colour6"
setw -g window-status-separator ""
setw -g window-status-bg "colour8"
set -g status-left ""
set -g status-right "#[fg=colour7,bg=colour0] %H:%M "
setw -g window-status-format "#[fg=colour7,bg=colour8] #I #[fg=colour7,bg=colour8]#W "
setw -g window-status-current-format "#[fg=colour8,bg=colour0,nobold,nounderscore]#[fg=colour7,bg=colour0] #W #[fg=colour0,bg=colour8,nobold,nounderscore]"
