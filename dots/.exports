# --files: List files that would be searched but do not search
# --no-ignore: Do not respect .gitignore, etc...
# --hidden: Search hidden files and folders
# --follow: Follow symlinks
# --glob: Additional conditions for search (in this case ignore everything in the .git/ folder)

# Configure fzf to use rg
export FZF_DEFAULT_COMMAND='rg --files --no-ignore --hidden --follow --glob "!.git/*" -g "!*.pyc"'

 # Preferred editor for local and remote sessions
export EDITOR='nvim'

# Pyenv Autocompletion
export PYENV_ROOT=~/.pyenv

# Set terminal colors if tmux is enabled
# export TERM=tmux-256color

# disbale underlining paths with zsh syntax highlighting
ZSH_HIGHLIGHT_STYLES[path]=none

POWERLEVEL9K_LEFT_PROMPT_ELEMENTS=(ssh root_indicator dir vcs pyenv rbenv virtualenv vi_mode)
POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS=(status)
POWERLEVEL9K_DIR_DEFAULT_BACKGROUND='004'
POWERLEVEL9K_DIR_HOME_BACKGROUND='004'
POWERLEVEL9K_DIR_HOME_SUBFOLDER_BACKGROUND='004'
POWERLEVEL9K_BATTERY_VERBOSE='false'
POWERLEVEL9K_SHORTEN_DIR_LENGTH=1
POWERLEVEL9K_SHORTEN_STRATEGY='truncate_from_right'
POWERLEVEL9K_SHORTEN_DELIMITER=''
POWERLEVEL9K_VCS_CLEAN_BACKGROUND='002'
POWERLEVEL9K_VCS_MODIFIED_BACKGROUND='005'
POWERLEVEL9K_VCS_UNTRACKED_BACKGROUND='011'
POWERLEVEL9K_PYENV_BACKGROUND='004'
POWERLEVEL9K_PYENV_FOREGROUND='003'
POWERLEVEL9K_VIRTUALENV_FOREGROUND='003'
POWERLEVEL9K_RBENV_BACKGROUND='001'
POWERLEVEL9K_RBENV_FOREGROUND='015'
POWERLEVEL9K_PROMPT_ADD_NEWLINE='true'
POWERLEVEL9K_PROMPT_ON_NEWLINE='true'
POWERLEVEL9K_MULTILINE_FIRST_PROMPT_PREFIX=''
POWERLEVEL9K_MULTILINE_SECOND_PROMPT_PREFIX=$'%F{magenta}\uf054 %f'
POWERLEVEL9K_VI_MODE_INSERT_FOREGROUND='000'
POWERLEVEL9K_VI_MODE_INSERT_BACKGROUND='002'
POWERLEVEL9K_VI_MODE_NORMAL_FOREGROUND='000'
POWERLEVEL9K_VI_MODE_NORMAL_BACKGROUND='001'
POWERLEVEL9K_VI_INSERT_MODE_STRING='\uf040'
POWERLEVEL9K_VI_COMMAND_MODE_STRING='\uf245'
POWERLEVEL9K_PYTHON_ICON='\ue606 '

export KEYTIMEOUT=1

# Set up prompt
# export VIRTUAL_ENV_DISABLE_PROMPT=1
