# Mode Activation
lctrl - space                :   khd -e "mode activate switcher"
switcher + lctrl - space     :   khd -e "mode activate default"
swap + lctrl - space         :   khd -e "mode activate default"
pane + lctrl - space         :   khd -e "mode activate default"

switcher - 0x35 : khd -e "mode activate default"
swap - 0x35     : khd -e "mode activate default"
pane - 0x35     : khd -e "mode activate default"


# Mode Colors

# Default (blue)
khd mode default  on_enter chunkc border::color 0xFF72bef2
# Switcher (yellow)
khd mode switcher on_enter chunkc border::color 0xFFc69a6d
# Swap (red)
khd mode swap     on_enter chunkc border::color 0xFFe88388
# Pane (purple)
khd mode pane     on_enter chunkc border::color 0xFFd291e4


# Disable focus follows mouse
switcher - backspace   :   khd -e 'chunkc set mouse_follows_focus';\
                           khd -e 'mode activate default'
# Restart kwm
switcher - 8           :   brew services restart chunkwm
switcher - 9           :   brew services restart khd

# --------------- switcher mode -----------------------
switcher - a           :   khd -e "mode activate swap"
switcher - d           :   khd -e "mode activate pane"
switcher - r           :   khd -e "reload" # reload config

switcher - return      :   open -na /Applications/iTerm.app;\
                           khd -e "mode activate default"

# focus windows
switcher - h           :   chunkc tiling::window --focus west
switcher - l           :   chunkc tiling::window --focus east
switcher - j           :   chunkc tiling::window --focus south
switcher - k           :   chunkc tiling::window --focus north

# focus monitors
switcher - n           :   chunkc tiling::monitor -f next
switcher - m           :   chunkc tiling::monitor -f prev


# --------------- swap mode -----------------------
swap - d               :   khd -e "mode activate pane"
swap - s               :   khd -e "mode activate switcher"

swap - h               :   chunkc tiling::window --swap west
swap - j               :   chunkc tiling::window --swap south
swap - k               :   chunkc tiling::window --swap north
swap - l               :   chunkc tiling::window --swap east

swap + shift - h       :   chunkc tiling::window --warp west
swap + shift - j       :   chunkc tiling::window --warp south
swap + shift - k       :   chunkc tiling::window --warp north
swap + shift - l       :   chunkc tiling::window --warp east

# send to monitor
swap - n               :   chunkc tiling::window --send-to-monitor next
swap - m               :   chunkc tiling::window --send-to-monitor prev

# send to monitor with focus
swap + shift - n       :   chunkc tiling::window --send-to-monitor next;\
                           chunkc tiling::monitor -f next
swap + shift - m       :   chunkc tiling::window --send-to-monitor prev;\
                           chuckc tiling::monitor -f prev


# --------------- pane mode -----------------------
pane - a               :   khd -e "mode activate swap"
pane - s               :   khd -e "mode activate switcher"

# gaps and padding
pane - p               :   chunkc tiling::desktop --padding inc
pane - g               :   chunkc tiling::desktop --gap inc
pane + shift - p       :   chunkc tiling::desktop --padding dec
pane + shift - g       :   chunkc tiling::desktop --gap dec
pane - t               :   chunkc tiling::desktop --toggle offset


pane - f               :   chunkc tiling::window --toggle fullscreen
pane + shit - f        :   chunkc tiling::window --toggle native-fullscreen
pane - r               :   chunkc tiling::desktop --rotate 90

pane - m               :   chunkc tiling::window --toggle split

pane - h               :   chunkc tiling::window --use-temporary-ratio 0.1 --adjust-window-edge west
pane - j               :   chunkc tiling::window --use-temporary-ratio 0.1 --adjust-window-edge south
pane - k               :   chunkc tiling::window --use-temporary-ratio 0.1 --adjust-window-edge north
pane - l               :   chunkc tiling::window --use-temporary-ratio 0.1 --adjust-window-edge east
pane + shift - h       :   chunkc tiling::window --use-temporary-ratio -0.1 --adjust-window-edge west
pane + shift - j       :   chunkc tiling::window --use-temporary-ratio -0.1 --adjust-window-edge south
pane + shift - k       :   chunkc tiling::window --use-temporary-ratio -0.1 --adjust-window-edge north
pane + shift - l       :   chunkc tiling::window --use-temporary-ratio -0.1 --adjust-window-edge east

lctrl - h         ![iTerm2, Emacs]      :   khd -p "- left"
lctrl - j         ![iTerm2, Emacs]      :   khd -p "- down"
lctrl - k         ![iTerm2, Emacs]      :   khd -p "- up"
lctrl - l         ![iTerm2, Emacs]      :   khd -p "- right"
