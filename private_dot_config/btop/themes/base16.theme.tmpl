{{- $t := index .themes .theme -}}
{{- $p := $t.palette -}}
# base16 theme: {{ $t.name }}
# Auto-generated by chezmoi from .chezmoidata/theme.yaml — do not edit directly.
# To change theme: update `theme` in ~/.local/share/chezmoi/.chezmoidata/theme.yaml
# then run `chezmoi apply`.
#
# Base16 color role reference:
#   base00 = background       base08 = red (variables, errors)
#   base01 = alt background   base09 = orange (integers, constants)
#   base02 = selection        base0A = yellow (classes, search)
#   base03 = comments         base0B = green (strings)
#   base04 = dark fg          base0C = cyan (support, regex)
#   base05 = foreground       base0D = blue (functions, headings)
#   base06 = fg alt           base0E = magenta (keywords)
#   base07 = bright white     base0F = violet/deprecated

# Main background — empty for terminal default / transparent
theme[main_bg]="{{ $p.base00 }}"

# Main text color
theme[main_fg]="{{ $p.base05 }}"

# Title color for boxes
theme[title]="{{ $p.base05 }}"

# Highlight color for keyboard shortcuts
theme[hi_fg]="{{ $p.base0D }}"

# Background color of selected item in processes box
theme[selected_bg]="{{ $p.base02 }}"

# Foreground color of selected item in processes box
theme[selected_fg]="{{ $p.base05 }}"

# Color of inactive/disabled text
theme[inactive_fg]="{{ $p.base03 }}"

# Color of text appearing on top of graphs (uptime, network scale)
theme[graph_text]="{{ $p.base04 }}"

# Background color of percentage meters
theme[meter_bg]="{{ $p.base02 }}"

# Misc colors for processes box (mini cpu graphs, memory graph, status text)
theme[proc_misc]="{{ $p.base0B }}"

# CPU box outline color
theme[cpu_box]="{{ $p.base0D }}"

# Memory/disks box outline color
theme[mem_box]="{{ $p.base0B }}"

# Net up/down box outline color
theme[net_box]="{{ $p.base08 }}"

# Processes box outline color
theme[proc_box]="{{ $p.base0C }}"

# Box divider line and small boxes line color
theme[div_line]="{{ $p.base02 }}"

# Temperature graph colors (cool → warm → hot)
theme[temp_start]="{{ $p.base0C }}"
theme[temp_mid]="{{ $p.base0A }}"
theme[temp_end]="{{ $p.base08 }}"

# CPU graph colors (low → mid → high)
theme[cpu_start]="{{ $p.base0B }}"
theme[cpu_mid]="{{ $p.base0A }}"
theme[cpu_end]="{{ $p.base08 }}"

# Mem/Disk free meter
theme[free_start]="{{ $p.base0C }}"
theme[free_mid]=""
theme[free_end]=""

# Mem/Disk cached meter
theme[cached_start]="{{ $p.base0D }}"
theme[cached_mid]=""
theme[cached_end]=""

# Mem/Disk available meter
theme[available_start]="{{ $p.base0A }}"
theme[available_mid]=""
theme[available_end]=""

# Mem/Disk used meter
theme[used_start]="{{ $p.base08 }}"
theme[used_mid]=""
theme[used_end]=""

# Download graph colors
theme[download_start]="{{ $p.base09 }}"
theme[download_mid]=""
theme[download_end]=""

# Upload graph colors
theme[upload_start]="{{ $p.base0E }}"
theme[upload_mid]=""
theme[upload_end]=""

# Process box color gradient for threads, mem and cpu usage
theme[process_start]="{{ $p.base0B }}"
theme[process_mid]="{{ $p.base0C }}"
theme[process_end]="{{ $p.base0D }}"
