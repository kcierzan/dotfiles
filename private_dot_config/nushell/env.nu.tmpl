# env.nu — Nushell environment configuration
# Managed by chezmoi

# Environment variables
$env.EDITOR = "nvim"
$env.VISUAL = "nvim"
$env.ALTERNATE_EDITOR = ""
$env.PAGER = "less"
$env.LANG = "en_US.UTF-8"
$env.LC_ALL = "en_US.UTF-8"
$env.XDG_CONFIG_HOME = $"($env.HOME)/.config"

# Terminal and tools
$env.CLICOLOR = "1"
$env.LESS = "-F -g -i -M -R -S -w -X"
$env.VIRTUAL_ENV_DISABLE_PROMPT = "1"
$env.MOZ_ENABLE_WAYLAND = "1"

# Development paths
$env.GOPATH = ($env.HOME | path join "go")

# Other environment variables
$env.OBJC_DISABLE_INITIALIZE_FORK_SAFETY = "YES"
$env.LSP_USE_PLISTS = "t"
$env.MISE_LOG_LEVEL = "error"

# Build PATH
let base_paths = [
  ($env.HOME | path join ".bootstrap" "resources" "bin")
  ($env.HOME | path join ".local" "bin")
  ($env.HOME | path join "bin")
  ($env.HOME | path join "go" "bin")
{{- if eq .chezmoi.os "darwin" }}
  "/opt/homebrew/opt/postgresql@15/bin"
  "/opt/homebrew/bin"
  "/opt/homebrew/sbin"
  "/opt/homebrew/opt/coreutils/libexec/gnubin"
{{- end }}
  ($env.HOME | path join ".local" "share" "mise" "shims")
  "/usr/local/bin"
  "/usr/local/sbin"
  "/Applications/Ghostty.app/Contents/MacOS"
  "/usr/bin"
  "/usr/sbin"
  "/bin"
  "/sbin"
]

$env.PATH = (
  $base_paths
  | where { |p| $p | path exists }
  | append ($env.PATH? | default "" | split row (char esep) | where { |p| $p | is-not-empty })
  | uniq
)

# Set SHELL to nushell
$env.SHELL = (which nu | get 0.path)

let xdg_nu_config_dir = $"($env.XDG_CONFIG_HOME)/nushell"

# Generate mise activation module
let mise_path = $xdg_nu_config_dir | path join mise.nu
if (which mise | is-not-empty) {
  ^mise activate nu | save --force $mise_path
} else {
  "export-env {}" | save --force $mise_path
}

# Generate zoxide integration
let zoxide_path = $xdg_nu_config_dir | path join zoxide.nu
if (which zoxide | is-not-empty) {
  ^zoxide init nushell | save --force $zoxide_path
} else {
  "" | save --force $zoxide_path
}

# Generate atuin integration
let atuin_path = $xdg_nu_config_dir | path join atuin.nu
if (which atuin | is-not-empty) {
  ^atuin init nu | save --force $atuin_path
} else {
  "" | save --force $atuin_path
}

# Generate carapace integration
$env.CARAPACE_BRIDGES = 'zsh,fish,bash,inshellisense'
let carapace_path = $xdg_nu_config_dir | path join carapace.nu
if (which carapace | is-not-empty) {
  ^carapace _carapace nushell | save --force $carapace_path
} else {
  "" | save --force $carapace_path
}
