cursor-style=bar
adjust-cursor-thickness=3
adjust-cell-height=8
font-thicken=true
adjust-underline-position=10%
custom-shader-animation=true
custom-shader=~/.config/ghostty/shaders/cursor-blaze.glsl
font-style=Regular
freetype-load-flags=no-hinting,no-force-autohint,no-monochrome,no-autohint
keybind=shift+enter=text:\n
font-family=Liga SFMono Nerd Font
{{- if eq .chezmoi.os "darwin" }}
command=/opt/homebrew/bin/nu --login --config ~/.config/nushell/config.nu --env-config ~/.config/nushell/env.nu
{{- else if eq .chezmoi.os "linux" }}
command=/usr/bin/nu --login --config ~/.config/nushell/config.nu --env-config ~/.config/nushell/env.nu
{{- end }}
theme=base16

