" vim: filetype=vim

" Make this config file the source of truth for all tridactyl config
sanitize tridactyllocal tridactylsync

set smoothscroll true

" Don't close tabs with a key on the home row
unbind d

" Reduce the scrolling sensitivity
bind j scrollline 5
bind k scrollline -5
bind d scrollline 10
bind u scrollline -10

bind J tabprev
bind K tabnext
bind x tabclose


" Disable tridactyl on sites that have lots of keyboard shortcuts
autocmd DocStart mail.google.com mode ignore
autocmd DocStart calendar.google.com mode ignore
autocmd DocStart notion.so mode ignore
autocmd DocStart trello.com mode ignore
autocmd DocStart xd.adobe.com mode ignore
autocmd DocStart localhost mode ignore

" Don't show the annoying mode
set modeindicator false

colourscheme dark
